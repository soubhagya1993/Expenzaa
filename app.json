{
  "expo": {
    "name": "Expenzaa",
    "slug": "expenzaa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F4F5FA",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soubhagya.expenzaa"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F4F5FA"
      },
      "package": "com.expense.tracker"
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}